{
	"name": "sokos-utbetalingsportalen",
	"type": "module",
	"version": "1.0.0",
	"scripts": {
		"astro": "astro",
		"dev": "astro dev",
		"dev:mock": "concurrently \"pnpm dev\" \"tsx mock/server.ts\"",
		"build": "astro check && astro build",
		"vitest": "vitest",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"prettier:format": "prettier --write '**/*.astro'",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky"
	},
	"dependencies": {
		"@astrojs/check": "0.9.8",
		"@astrojs/node": "10.0.5",
		"@astrojs/react": "5.0.3",
		"@grafana/faro-web-sdk": "2.3.1",
		"@navikt/aksel-icons": "7.40.0",
		"@navikt/ds-react": "7.40.0",
		"@navikt/oasis": "4.1.4",
		"@opentelemetry/sdk-node": "0.214.0",
		"astro": "6.1.8",
		"pino": "10.3.1",
		"pino-socket": "8.0.0",
		"prom-client": "15.1.3",
		"react": "19.2.4",
		"react-dom": "19.2.4",
		"react-error-boundary": "6.1.1",
		"swr": "2.4.1",
		"zod": "4.3.6"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.12",
		"@hono/node-server": "1.19.14",
		"@navikt/aksel-stylelint": "7.40.0",
		"@types/node": "25.6.0",
		"@types/react": "19.2.14",
		"@types/react-dom": "19.2.3",
		"concurrently": "9.2.1",
		"hono": "4.12.14",
		"husky": "9.1.7",
		"lint-staged": "16.4.0",
		"prettier": "3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"stylelint": "17.8.0",
		"stylelint-config-standard": "40.0.0",
		"tsx": "4.21.0",
		"typescript": "6.0.3",
		"vitest": "4.1.4"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.astro": "prettier --write",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=10.16.0",
		"node": ">=24.12.0"
	},
	"pnpm": {
		"overrides": {
			"protobufjs": "8.0.1"
		}
	}
}
