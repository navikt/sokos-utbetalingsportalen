{
	"name": "sokos-utbetalingsportalen",
	"type": "module",
	"version": "1.0.0",
	"scripts": {
		"astro": "astro",
		"dev": "astro dev",
		"dev:mock": "concurrently \"pnpm dev\" \"tsx mock/server.ts\"",
		"build": "astro check && astro build",
		"vitest": "vitest",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"prettier:format": "prettier --write '**/*.astro'",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/node": "10.1.1",
		"@astrojs/react": "5.0.5",
		"@grafana/faro-react": "2.7.1",
		"@grafana/faro-web-sdk": "2.7.1",
		"@grafana/faro-web-tracing": "2.7.1",
		"@navikt/aksel-icons": "7.40.0",
		"@navikt/ds-react": "7.40.0",
		"@navikt/oasis": "4.1.4",
		"@opentelemetry/sdk-node": "0.218.0",
		"astro": "6.3.8",
		"pino": "10.3.1",
		"pino-socket": "8.0.0",
		"prom-client": "15.1.3",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.4.16",
		"@hono/node-server": "2.0.4",
		"@navikt/aksel-stylelint": "7.40.0",
		"@types/node": "25.9.2",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"concurrently": "10.0.3",
		"hono": "4.12.25",
		"husky": "9.1.7",
		"lint-staged": "17.0.7",
		"prettier": "3.8.3",
		"prettier-plugin-astro": "0.14.1",
		"stylelint": "17.13.0",
		"stylelint-config-standard": "40.0.0",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"vitest": "4.1.8"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.astro": "prettier --write",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.1.2",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
