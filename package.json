{
	"name": "sokos-utbetalingsportalen",
	"type": "module",
	"version": "1.0.0",
	"scripts": {
		"astro": "astro",
		"dev": "astro dev",
		"dev:mock": "concurrently \"pnpm dev\" \"tsx mock/server.ts\"",
		"build": "astro check && astro build",
		"vitest": "vitest",
		"biome:check": "biome check --files-ignore-unknown=true",
		"biome:fix": "biome check --write --no-errors-on-unmatched",
		"prettier:format": "prettier --write '**/*.astro'",
		"stylelint:check": "stylelint '**/*.css'",
		"stylelint:fix": "stylelint '**/*.css' --fix",
		"prepare": "husky",
		"pnpm:resolve": "node scripts/resolve-pnpm-version.mjs"
	},
	"dependencies": {
		"@astrojs/check": "0.9.9",
		"@astrojs/node": "11.0.0",
		"@astrojs/react": "6.0.0",
		"@grafana/faro-react": "2.7.1",
		"@grafana/faro-web-sdk": "2.7.1",
		"@grafana/faro-web-tracing": "2.7.1",
		"@navikt/aksel-icons": "7.40.0",
		"@navikt/ds-react": "7.40.0",
		"@navikt/oasis": "4.1.4",
		"@opentelemetry/sdk-node": "0.219.0",
		"astro": "7.0.0",
		"pino": "10.3.1",
		"pino-socket": "8.0.0",
		"prom-client": "15.1.3",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"zod": "4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "2.5.0",
		"@hono/node-server": "2.0.5",
		"@navikt/aksel-stylelint": "7.40.0",
		"@types/node": "25.9.3",
		"@types/react": "19.2.17",
		"@types/react-dom": "19.2.3",
		"concurrently": "10.0.3",
		"hono": "4.12.25",
		"husky": "9.1.7",
		"lint-staged": "17.0.7",
		"prettier": "3.8.4",
		"prettier-plugin-astro": "0.14.1",
		"stylelint": "17.13.0",
		"stylelint-config-standard": "40.0.0",
		"tsx": "4.22.4",
		"typescript": "6.0.3",
		"vitest": "4.1.9"
	},
	"lint-staged": {
		"*.{js,ts,cjs,mjs,d.cts,d.mts,jsx,tsx,json,jsonc}": "biome check --write --no-errors-on-unmatched",
		"*.astro": "prettier --write",
		"*.css": "stylelint --fix"
	},
	"engines": {
		"pnpm": ">=11.5.3",
		"node": ">=24.14.1"
	},
	"packageManager": "pnpm@11.5.3+sha512.7ac1c919341c213a34dc0d02afb7143c5c26ac26ee8c4782deea821b8ac64d2134a081fd8941dae6e29bbb48f58dfc2b7fbceeccc07cb2f09d219d342a4969ed"
}
