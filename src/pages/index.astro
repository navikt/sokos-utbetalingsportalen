---
import AppSwitcher from "@components/appswitcher/AppSwitcher";
import AppSwitcherSkeleton from "@components/appswitcher/AppSwitcherSkeleton";
import WelcomePanel from "@components/welcomepanel/WelcomePanel";
import { getExternalLinks } from "@config/externalLinks";
import Layout from "@layouts/Layout.astro";
import styles from "./_index.module.css";

const userData = Astro.locals.userData;

const currentHour = new Date().getHours();
const greeting =
	currentHour < 10
		? "God morgen"
		: currentHour < 12
			? "God formiddag"
			: currentHour < 18
				? "God ettermiddag"
				: "God kveld";

const naisClusterName = process.env.NAIS_CLUSTER_NAME ?? "";
const utbetalingsportalenEnvironment = process.env.UTBETALINGSPORTALEN_ENVIRONMENT ?? "";
const externalLinks = getExternalLinks(naisClusterName, utbetalingsportalenEnvironment);
---

<Layout title="Hjem">
  <div class={styles["home"]}>
    <div class={styles["home__content"]}>
      <WelcomePanel greeting={greeting} name={userData.name} />
      <AppSwitcher adGroups={userData.groups} externalLinks={externalLinks} client:only="react">
        <AppSwitcherSkeleton slot="fallback" />
      </AppSwitcher>
    </div>
  </div>
</Layout>
