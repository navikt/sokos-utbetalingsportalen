{
	"extends": "astro/tsconfigs/strict",
	"compilerOptions": {
		"jsx": "react-jsx",
		"jsxImportSource": "react",
		"types": ["astro/client"],
		"paths": {
			"@components/*": ["./src/components/*"],
			"@layouts/*": ["./src/layouts/*"],
			"@pages/*": ["./src/pages/*"],
			"@types/*": ["./src/types/*"],
			"@schema/*": ["./src/types/schema/*"],
			"@utils/*": ["./src/utils/*"],
			"@config/*": ["./src/config/*"]
		}
	},
	"include": [".astro/types.d.ts", "src/**/*"],
	"exclude": ["node_modules", "dist"]
}
